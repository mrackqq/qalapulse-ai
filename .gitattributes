# Normalize line endings: store text as LF in the repo
* text=auto eol=lf

# Explicit text types
*.py    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.ini   text eol=lf
*.txt   text eol=lf
*.env   text eol=lf

# Binary assets
*.pptx  binary
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.ico   binary
